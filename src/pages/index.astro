---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Triton France | Home Acoustic Research & Technical Vocabulary";
const description = "Comprehensive research into home acoustic design, technical terminology, STC ratings, NRC values, and residential sound science. Market size $18.7B by 2028.";
---

<BaseLayout 
  title={title} 
  description={description}
  heroTitle="Acoustic"
  heroSubtitle="Research"
  heroDescription="Research-driven insights into home acoustic design, technical vocabulary, and emerging trends in residential sound science."
>
  <!-- Modular Grid: Content Cards -->
  <section class="p-8 lg:p-16 bg-background-light">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
        <div class="max-w-xl">
          <h2 class="text-xs font-black uppercase tracking-[0.4em] text-primary mb-4">Research Framework</h2>
          <h3 class="text-4xl md:text-5xl font-black uppercase tracking-tighter">Engineered for residential acoustic excellence.</h3>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Card 1 -->
        <a href="/home-acoustics/" class="group bg-white border-2 border-slate-900 hover:border-primary transition-colors p-6 flex flex-col justify-between aspect-[3/4]">
          <div>
            <span class="material-symbols-outlined text-4xl mb-6 text-primary">home</span>
            <h4 class="text-2xl font-black uppercase mb-4">Overview</h4>
            <p class="text-slate-600 text-sm font-medium">Comprehensive introduction to home acoustic principles, STC ratings, and NRC values.</p>
          </div>
          <span class="text-xs font-black uppercase tracking-widest flex items-center gap-2 group-hover:text-primary transition-colors">
            Explore <span class="material-symbols-outlined text-sm group-hover:translate-x-2 transition-transform">arrow_right_alt</span>
          </span>
        </a>
        <!-- Card 2 -->
        <a href="/home-acoustics/history/" class="group bg-slate-900 text-white border-2 border-slate-900 p-6 flex flex-col justify-between aspect-[3/4]">
          <div>
            <span class="material-symbols-outlined text-4xl mb-6 text-primary">history</span>
            <h4 class="text-2xl font-black uppercase mb-4">History</h4>
            <p class="text-slate-400 text-sm font-medium">Evolution from 19th century speakers to modern smart acoustic systems.</p>
          </div>
          <span class="text-xs font-black uppercase tracking-widest flex items-center gap-2 group-hover:text-primary transition-colors">
            Timeline <span class="material-symbols-outlined text-sm group-hover:translate-x-2 transition-transform">arrow_right_alt</span>
          </span>
        </a>
        <!-- Card 3 -->
        <a href="/home-acoustics/technical-deep-dive/" class="group bg-white border-2 border-slate-900 hover:border-primary transition-colors p-6 flex flex-col justify-between aspect-[3/4]">
          <div>
            <span class="material-symbols-outlined text-4xl mb-6 text-primary">architecture</span>
            <h4 class="text-2xl font-black uppercase mb-4">Technical</h4>
            <p class="text-slate-600 text-sm font-medium">STC ratings, NRC values, absorption, diffusion, and construction techniques.</p>
          </div>
          <span class="text-xs font-black uppercase tracking-widest flex items-center gap-2 group-hover:text-primary transition-colors">
            Deep-Dive <span class="material-symbols-outlined text-sm group-hover:translate-x-2 transition-transform">arrow_right_alt</span>
          </span>
        </a>
        <!-- Card 4 -->
        <a href="/home-acoustics/ontology/" class="group bg-primary text-white border-2 border-slate-900 p-6 flex flex-col justify-between aspect-[3/4]">
          <div>
            <span class="material-symbols-outlined text-4xl mb-6">menu_book</span>
            <h4 class="text-2xl font-black uppercase mb-4">Ontology</h4>
            <p class="text-blue-100 text-sm font-medium">Complete glossary of acoustic terminology and technical definitions.</p>
          </div>
          <span class="text-xs font-black uppercase tracking-widest flex items-center gap-2 group-hover:text-white transition-colors">
            Glossary <span class="material-symbols-outlined text-sm group-hover:translate-x-2 transition-transform">arrow_right_alt</span>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="grid grid-cols-1 md:grid-cols-4 border-b-2 border-slate-900">
    <div class="p-10 border-b-2 md:border-b-0 md:border-r-2 border-slate-900 flex flex-col gap-4 group hover:bg-primary transition-colors bg-white">
      <p class="text-xs font-black uppercase tracking-[0.3em] text-slate-500 group-hover:text-white transition-colors">STC Range</p>
      <p class="text-4xl font-black group-hover:text-white transition-colors">25-70+</p>
      <p class="text-slate-500 text-sm group-hover:text-white transition-colors">Sound blocking scale</p>
    </div>
    <div class="p-10 border-b-2 md:border-b-0 md:border-r-2 border-slate-900 flex flex-col gap-4 group hover:bg-primary transition-colors bg-white">
      <p class="text-xs font-black uppercase tracking-[0.3em] text-slate-500 group-hover:text-white transition-colors">NRC Scale</p>
      <p class="text-4xl font-black group-hover:text-white transition-colors">0.0-1.0</p>
      <p class="text-slate-500 text-sm group-hover:text-white transition-colors">Absorption rating</p>
    </div>
    <div class="p-10 border-b-2 md:border-b-0 md:border-r-2 border-slate-900 flex flex-col gap-4 group hover:bg-primary transition-colors bg-white">
      <p class="text-xs font-black uppercase tracking-[0.3em] text-slate-500 group-hover:text-white transition-colors">Market Size</p>
      <p class="text-4xl font-black group-hover:text-white transition-colors">$18.7B</p>
      <p class="text-slate-500 text-sm group-hover:text-white transition-colors">Projected 2028</p>
    </div>
    <div class="p-10 flex flex-col gap-4 group hover:bg-primary transition-colors bg-slate-50">
      <p class="text-xs font-black uppercase tracking-[0.3em] text-slate-500 group-hover:text-white transition-colors">Research Topics</p>
      <p class="text-4xl font-black group-hover:text-white transition-colors">7 Pillars</p>
      <p class="text-slate-500 text-sm group-hover:text-white transition-colors">Comprehensive coverage</p>
    </div>
  </section>

  <!-- Featured Content -->
  <section class="border-b-2 border-slate-900">
    <div class="flex flex-col lg:flex-row">
      <div class="w-full lg:w-1/2 p-8 lg:p-16 bg-white">
        <h2 class="text-xs font-black uppercase tracking-[0.4em] text-primary mb-6">Research Focus</h2>
        <h3 class="text-4xl md:text-5xl font-black uppercase tracking-tighter mb-8 leading-[0.9]">The Science of<br/><span class="text-primary">Residential Acoustics</span></h3>
        
        <div class="space-y-6 text-slate-600">
          <p class="leading-relaxed">
            Home acoustic trends in 2026 represent a fundamental shift where sound quality has become as essential to interior design as aesthetics. Acoustic solutions have evolved from technical afterthoughts into central design elements that enhance both comfort and visual appeal.
          </p>
          
          <p class="leading-relaxed">
            According to <a href="https://www.epa.gov/" target="_blank" rel="noopener" class="text-primary font-bold hover:underline">EPA research</a>, sound quality directly impacts human wellbeing, productivity, and overall experience. Acoustic comfort has become a true design essential, particularly as living rooms now serve multiple functions—entertaining, relaxing, working, and recording.
          </p>

          <div class="bg-slate-50 p-6 border-2 border-slate-200">
            <h4 class="font-black uppercase tracking-widest text-xs mb-4 text-primary">Key Research Areas</h4>
            <ul class="space-y-2 text-sm">
              <li class="flex items-start gap-2">
                <span class="material-symbols-outlined text-primary text-sm">check</span>
                <span>STC and NRC measurement standards</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="material-symbols-outlined text-primary text-sm">check</span>
                <span>Biophilic and sustainable materials</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="material-symbols-outlined text-primary text-sm">check</span>
                <span>Smart IoT acoustic systems</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="material-symbols-outlined text-primary text-sm">check</span>
                <span>Leading manufacturers and products</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
      
      <div class="w-full lg:w-1/2 p-8 lg:p-16 bg-slate-50 border-l-0 lg:border-l-2 border-slate-900">
        <h2 class="text-xs font-black uppercase tracking-[0.4em] text-slate-400 mb-6">Market Intelligence</h2>
        <h3 class="text-4xl md:text-5xl font-black uppercase tracking-tighter mb-8 leading-[0.9]">Industry<br/><span class="text-primary">Landscape.</span></h3>
        
        <div class="space-y-8">
          <div class="flex gap-6 pb-6 border-b border-slate-200">
            <span class="text-primary font-black text-2xl">01</span>
            <div>
              <p class="font-black uppercase text-sm mb-2">Leading Manufacturer</p>
              <p class="text-slate-500"><a href="https://www.acousticalsolutions.com/" target="_blank" rel="noopener" class="text-primary font-bold hover:underline">Acoustical Solutions, Inc.</a> holds 12.6% market share as of January 2026.</p>
            </div>
          </div>
          <div class="flex gap-6 pb-6 border-b border-slate-200">
            <span class="text-primary font-black text-2xl">02</span>
            <div>
              <p class="font-black uppercase text-sm mb-2">Insulation Leaders</p>
              <p class="text-slate-500">Rockwool, Knauf, and Saint-Gobain dominate acoustic insulation innovation.</p>
            </div>
          </div>
          <div class="flex gap-6 pb-6 border-b border-slate-200">
            <span class="text-primary font-black text-2xl">03</span>
            <div>
              <p class="font-black uppercase text-sm mb-2">Growth Trajectory</p>
              <p class="text-slate-500">Market expanding at 6%+ CAGR driven by remote work and home entertainment trends.</p>
            </div>
          </div>
          <div class="flex gap-6">
            <span class="text-primary font-black text-2xl">04</span>
            <div>
              <p class="font-black uppercase text-sm mb-2">Emerging Tech</p>
              <p class="text-slate-500">Smart systems, biophilic materials, and parametric design lead innovation.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="p-8 lg:p-16 bg-slate-900 text-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-xs font-black uppercase tracking-[0.4em] text-primary mb-4">Start Exploring</h2>
      <h3 class="text-4xl md:text-6xl font-black uppercase tracking-tighter mb-8">Begin Your Research</h3>
      <p class="text-slate-400 text-lg mb-8 max-w-2xl mx-auto">
        Comprehensive coverage of home acoustic science across seven interconnected pillars. From historical evolution to emerging technologies. For those also perfecting their morning routine, a <a href="https://completehomebarista.com/checklists/">home barista checklist</a> is an essential companion to any well-designed kitchen space.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/home-acoustics/" class="px-8 py-4 bg-primary text-white font-black uppercase tracking-widest text-sm hover:bg-white hover:text-slate-900 transition-colors border-2 border-primary">
          Start with Overview
        </a>
        <a href="/home-acoustics/technical-deep-dive/" class="px-8 py-4 bg-transparent text-white font-black uppercase tracking-widest text-sm hover:bg-white hover:text-slate-900 transition-colors border-2 border-white">
          Technical Deep-Dive
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
