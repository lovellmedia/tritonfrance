---
const currentYear = new Date().getFullYear();
---

<footer class="bg-background-light border-t border-slate-200 pt-16 pb-8">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-12 mb-16">
      <div class="col-span-2">
        <div class="flex items-center gap-2 text-primary mb-6">
          <span class="material-symbols-outlined text-3xl">surround_sound</span>
          <span class="text-slate-900 text-xl font-bold tracking-tight">Triton France</span>
        </div>
        <p class="text-slate-500 max-w-xs text-sm leading-relaxed">
          Leading resource for home acoustic trends and technical vocabulary. Explore the science of sound in residential spaces.
        </p>
      </div>
      <div>
        <h4 class="text-slate-900 font-bold text-sm uppercase tracking-widest mb-6">Topics</h4>
        <ul class="space-y-4">
          <li><a class="text-slate-500 text-sm hover:text-primary" href="/home-acoustics/">Overview</a></li>
          <li><a class="text-slate-500 text-sm hover:text-primary" href="/home-acoustics/history/">History</a></li>
          <li><a class="text-slate-500 text-sm hover:text-primary" href="/home-acoustics/technical-deep-dive/">Technical</a></li>
          <li><a class="text-slate-500 text-sm hover:text-primary" href="/home-acoustics/trends/">Trends</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-slate-900 font-bold text-sm uppercase tracking-widest mb-6">Resources</h4>
        <ul class="space-y-4">
          <li><a class="text-slate-500 text-sm hover:text-primary" href="/home-acoustics/tools/">Tools</a></li>
          <li><a class="text-slate-500 text-sm hover:text-primary" href="/home-acoustics/ontology/">Ontology</a></li>
          <li><a class="text-slate-500 text-sm hover:text-primary" href="/home-acoustics/challenges/">Challenges</a></li>
        </ul>
      </div>
    </div>
    <div class="pt-8 border-t border-slate-200 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-slate-500 text-xs">&copy; {currentYear} tritonfrance.com. All rights reserved.</p>
      <div class="flex gap-6">
        <a class="text-slate-500 text-xs hover:text-primary" href="/home-acoustics/">Home Acoustics Resource</a>
      </div>
    </div>
  </div>
</footer>
